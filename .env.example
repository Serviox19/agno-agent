# OpenRouter (primary model provider)
OPENROUTER_API_KEY=your-openrouter-api-key

# xAI / Grok (native X search for news gatherer — no per-post X API fees)
XAI_API_KEY=your-xai-api-key

# Ollama Cloud (for minimax-m2.5 free tier)
OLLAMA_API_KEY=your-ollama-api-key

# Twitter/X API
X_BEARER_TOKEN=your-x-bearer-token
X_CONSUMER_KEY=your-x-consumer-key
X_CONSUMER_SECRET=your-x-consumer-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Slack
SLACK_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_SARGE_CHANNEL=your-life-goals-channel-id

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=agno_agents
